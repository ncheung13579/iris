# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# Data (large files — include download script instead)
data/raw/
data/processed/*.json
!data/processed/.gitkeep

# Checkpoints (large — stored on Google Drive)
# For submission: use checkpoints/download_checkpoints.py to fetch them
checkpoints/*.pt
checkpoints/*.npz
checkpoints/*.npy
!checkpoints/.gitkeep
!checkpoints/download_checkpoints.py

# Results — INCLUDED for submission (force-added)
# results/figures/*.png
# results/metrics/*.json
results/feature_dashboards/*.png
!results/feature_dashboards/.gitkeep

# Archived checkpoints (large binary files)
archive/**/*.pt
archive/**/*.npz
archive/**/*.npy

# Environment
.env
.venv/
venv/
.test_env/

# Project status (internal working doc, not for submission)
PROJECT_STATUS.md

# Private workspace (non-submission files: archived versions, one-off
# scripts, exploratory checkpoints, internal status docs)
/_private/

# Report source and Word version: only the PDF is tracked for grading.
# The DOCX and the markdown source remain locally for rebuild purposes
# but are not part of the submission surface.
docs/Project_Report.md
docs/IRIS_Final_Report.docx

# AI-assistance guardrails (not part of the submission)
CLAUDE.md

# Notebook pre-run snapshots. The source notebooks are tracked; the
# matching *_results.ipynb variants are regenerated by running the
# source notebooks and should not be versioned.
notebooks/*_results.ipynb

# Ancillary notebooks not part of the main experimental flow and not
# referenced by the report's Appendix B.
notebooks/demo.ipynb
notebooks/agent_model_comparison.ipynb

# Figures: the report PDF has them embedded; source notebooks and
# scripts regenerate them when run. Keep the directory via .gitkeep.
results/figures/*.png
!results/figures/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
rainbow_roastery_complete_guide_20260306.md
