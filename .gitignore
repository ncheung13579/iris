# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# Data (large files — include download script instead)
data/raw/
data/processed/*.json
!data/processed/.gitkeep

# Checkpoints: the files required to run the dashboard and reproduce the
# §5 detection results are tracked via Git LFS (see .gitattributes).
# The raw per-layer activation .npz files are not tracked. They are
# only needed to retrain the SAE from scratch, which is out of scope
# for grading and requires a GPU.
checkpoints/*.npz
!checkpoints/.gitkeep
!checkpoints/download_checkpoints.py

# Results — INCLUDED for submission (force-added)
# results/figures/*.png
# results/metrics/*.json
results/feature_dashboards/*.png
!results/feature_dashboards/.gitkeep

# Archived checkpoints (large binary files)
archive/**/*.pt
archive/**/*.npz
archive/**/*.npy

# Environment
.env
.venv/
venv/
.test_env/

# Project status (internal working doc, not for submission)
PROJECT_STATUS.md

# Private workspace (non-submission files: archived versions, one-off
# scripts, exploratory checkpoints, internal status docs)
/_private/

# Report artifacts: delivered to the professor separately, never
# committed. The PDF, DOCX, and markdown source all contain the
# author's email and student number on the title page and are not
# part of the public repo.
docs/IRIS_Final_Report.pdf
docs/IRIS_Final_Report.docx
docs/Project_Report.md

# AI-assistance guardrails (not part of the submission)
CLAUDE.md

# Notebook pre-run snapshots. The source notebooks are tracked; the
# matching *_results.ipynb variants are regenerated by running the
# source notebooks and should not be versioned.
notebooks/*_results.ipynb

# Ancillary notebooks not part of the main experimental flow and not
# referenced by the report's Appendix B.
notebooks/demo.ipynb
notebooks/agent_model_comparison.ipynb

# Figures: the report PDF has them embedded; source notebooks and
# scripts regenerate them when run. Keep the directory via .gitkeep.
results/figures/*.png
!results/figures/.gitkeep

# Scripts that are not part of the required pipeline. expand_dataset.py
# is referenced by notebook 08 so it stays tracked; the others are:
#   build_report.py          local-only tool for rebuilding the PDF
#                            from the (gitignored) markdown source
#   agent_cli.py             non-GUI alternative to launch.py; nothing
#                            in the grading flow depends on it
#   generate_deployment_figures.py  figures it produces are already
#                                   embedded in the final PDF
#   run_statistical_analysis.py  optional extra analyses; outputs are
#                                not consumed by any tracked pipeline
scripts/build_report.py
scripts/agent_cli.py
scripts/generate_deployment_figures.py
scripts/run_statistical_analysis.py

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
rainbow_roastery_complete_guide_20260306.md
